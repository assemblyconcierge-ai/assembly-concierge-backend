# Assembly Concierge Backend — Environment Variables
# Copy to .env and fill in real values before starting the server.
# Never commit .env to version control.

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
APP_BASE_URL=https://your-service.onrender.com

# ─── Database ────────────────────────────────────────────────────────────────
# Must start with postgres:// or postgresql://
DATABASE_URL=postgresql://user:password@host:5432/assembly_concierge

# ─── Redis (optional — queues degrade gracefully without it) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Airtable (mirror only — not source of truth) ────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_JOBS=Jobs

# ─── Email provider ──────────────────────────────────────────────────────────
# EMAIL_PROVIDER_API_KEY=
# EMAIL_FROM=noreply@assemblyconcierge.com

# ─── SMS provider ────────────────────────────────────────────────────────────
# SMS_PROVIDER_API_KEY=
# SMS_FROM=+1XXXXXXXXXX

# ─── File storage (S3-compatible) ────────────────────────────────────────────
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT=

# ─── Admin auth ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=change-me-to-a-64-char-random-hex-string

# ─── Webhook security ────────────────────────────────────────────────────────
# JOTFORM_WEBHOOK_SECRET=
# MAKE_WEBHOOK_SECRET=
