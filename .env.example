# Assembly Concierge Backend — Environment Variables
# Copy to .env and fill in real values before starting the server.
# Never commit .env to version control.

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
APP_BASE_URL=https://your-service.onrender.com
# Optional: comma-separated extra CORS origins for browser clients (e.g. local dev, staging)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://staging.example.com

# Public booking launch guards
PUBLIC_BOOKING_SAME_DAY_ENABLED=false
PUBLIC_BOOKING_FALLBACK_CONTRACTOR_COUNT=2
PUBLIC_BOOKING_UNITS_PER_CONTRACTOR_WINDOW=2
PUBLIC_BOOKING_SMALL_UNITS=1
PUBLIC_BOOKING_MEDIUM_UNITS=1
PUBLIC_BOOKING_LARGE_UNITS=2
PUBLIC_BOOKING_TREADMILL_UNITS=2

# ─── Database ────────────────────────────────────────────────────────────────
# Must start with postgres:// or postgresql://
DATABASE_URL=postgresql://user:password@host:5432/assembly_concierge

# ─── Redis (optional — queues degrade gracefully without it) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Airtable (mirror only — not source of truth) ────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_JOBS=Jobs

# ─── Email provider ──────────────────────────────────────────────────────────
# EMAIL_PROVIDER_API_KEY=
# EMAIL_FROM=noreply@assemblyconcierge.com

# ─── SMS provider ────────────────────────────────────────────────────────────
# SMS_PROVIDER_API_KEY=
# SMS_FROM=+1XXXXXXXXXX
# Base64 signing secret from Quo Settings -> Webhooks -> Reveal signing secret
# QUO_WEBHOOK_SIGNING_SECRET=

# ─── File storage (S3-compatible) ────────────────────────────────────────────
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT=

# ─── Admin auth ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=change-me-to-a-64-char-random-hex-string

# ─── Webhook security ────────────────────────────────────────────────────────
# JOTFORM_WEBHOOK_SECRET=
# MAKE_WEBHOOK_SECRET=
# Required in production for the contractor onboarding webhook URL's ?token= value.
JOTFORM_CONTRACTOR_ONBOARDING_WEBHOOK_TOKEN=change-me-to-a-random-secret
