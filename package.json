{
  "name": "assembly-concierge-backend",
  "version": "2.0.0",
  "description": "Assembly Concierge Backend MVP — PostgreSQL source of truth, Stripe webhooks, modular domain services",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node dist/src/db/migrate.js",
    "seed": "node dist/src/db/seed.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "seed:dev": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "bullmq": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "stripe": "^14.21.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  }
}
